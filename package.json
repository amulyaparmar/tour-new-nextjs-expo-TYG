{
  "name": "tour-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "build:web": "turbo build --filter=@tour/web",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "typecheck:web": "turbo typecheck --filter=@tour/web",
    "web": "turbo dev --filter=@tour/web",
    "admin": "turbo dev --filter=@tour/admin",
    "build:admin": "turbo build --filter=@tour/admin",
    "typecheck:admin": "turbo typecheck --filter=@tour/admin",
    "mobile": "turbo dev --filter=@tour/mobile",
    "mobile:build:ios": "npm --workspace @tour/mobile run build:ios",
    "mobile:submit:ios": "npm --workspace @tour/mobile run submit:ios",
    "mobile:testflight": "npm --workspace @tour/mobile run testflight"
  },
  "devDependencies": {
    "turbo": "^2.8.0",
    "typescript": "^6.0.3"
  }
}

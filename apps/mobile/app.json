{
  "expo": {
    "name": "Tour",
    "owner": "tourtyg",
    "slug": "tour-new-tour-you-tyg",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/tour-logo.png",
    "scheme": "tournewtouryoutyg",
    "userInterfaceStyle": "light",
    "experiments": {
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a30cd0f8-93f0-423b-979b-2c415aa6a5c4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.leasemagnets.tournewtouryou.tyg",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow Tour to record leasing conversations for session analysis and coaching.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.leasemagnets.tournewtouryou.tyg",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#087f8c"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Tour to record leasing conversations for session analysis and coaching.",
          "enableBackgroundRecording": true
        }
      ],
      "expo-live-activity",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Tour to record leasing conversations for session analysis and coaching."
        }
      ],
      "expo-video",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "a30cd0f8-93f0-423b-979b-2c415aa6a5c4"
      }
    }
  }
}

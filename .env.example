SUPABASE_PROJECT_ID=tkweddqlriikqgylsuxz
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://tkweddqlriikqgylsuxz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=https://tkweddqlriikqgylsuxz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
GOOGLE_PLACES_API_KEY=
TOUR_API_BASE_URL=https://tour.new
NEXT_PUBLIC_SITE_URL=https://tour.you
EXPO_PUBLIC_API_BASE_URL=http://localhost:3002

# Transcription provider: whisper (default, original) | deepgram | elevenlabs | gemini | aws
TRANSCRIBE_PROVIDER=whisper

# Google Gemini — multimodal audio transcription + sentiment/emotion insights.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_AUDIO_MODEL=gemini-3.6-flash

# OpenAI — used by the whisper provider (Whisper-1 STT + LLM diarization).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Deepgram — hosted STT + native diarization. Lowest setup: just the key.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# ElevenLabs Scribe — hosted STT + diarization with agent/customer role detection.
# detect_speaker_roles is enabled in code (maps agent → Agent, customer → Prospect).
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=scribe_v2
# ELEVENLABS_LANGUAGE_CODE=en

# AWS Transcribe — used only when TRANSCRIBE_PROVIDER=aws.
# Requires IAM credentials with Transcribe + S3 access (NOT the Bedrock token).
# The S3 bucket holds the audio Transcribe reads + the transcript JSON it writes.
# Minimal IAM policy:
#   transcribe:StartTranscriptionJob, transcribe:GetTranscriptionJob
#   s3:PutObject, s3:GetObject  on  arn:aws:s3:::<bucket>/*
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
TRANSCRIBE_S3_BUCKET=
TRANSCRIBE_LANGUAGE_CODE=en-US

# AWS Bedrock — Claude + OpenAI for rubric analysis and follow-up actions
# Long-term Bedrock API key (bearer token). Same key works for both providers.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-5
# Optional default OpenAI-on-Bedrock model (Mantle / Responses API)
# BEDROCK_OPENAI_MODEL=openai.gpt-5.4
# BEDROCK_OPENAI_BASE_URL=https://bedrock-mantle.us-east-1.api.aws/openai/v1

# Twilio SMS (rep contact texting on tour check-in). Optional in dev —
# check-in still works without it; texting is skipped/logged when unset.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=

# Property access-request email. The sender must be verified in Cloudflare Email Sending.
# Recommended: protected Cloudflare Email Worker (no Cloudflare API token in Vercel).
TOUR_EMAIL_WORKER_URL=
TOUR_EMAIL_WORKER_TOKEN=
# Optional direct REST fallback:
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=notifications@tour.report

# Comma-separated domains allowed to open and switch into any property session.
TOUR_GLOBAL_PROPERTY_ADMIN_DOMAINS=leasemagnets.com
